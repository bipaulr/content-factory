# Backend Environment Variables

# ============================================
# Database Configuration
# ============================================

# For LOCAL DEVELOPMENT (SQLite):
# Just leave USE_MONGODB as false, database will auto-create in ./campaigns/users.db

# For PRODUCTION (MongoDB Atlas - FREE TIER):
# 1. Go to https://www.mongodb.com/cloud/atlas
# 2. Create free account
# 3. Create a new cluster (free tier)
# 4. Get connection string: Cluster → Connect → Drivers
# 5. Copy the connection string and update below

USE_MONGODB=false
# MONGODB_URI=mongodb+srv://username:password@cluster-name.mongodb.net/content-factory?retryWrites=true&w=majority

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256

# ============================================
# Google OAuth (Optional for direct Google Auth)
# ============================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# Frontend Configuration
# ============================================
FRONTEND_URL=http://localhost:3000
